{
  "name": "schedule-dashboard",
  "version": "1.0.0",
  "description": "Live weekly schedule dashboard for club managers with admin approval workflow",
  "main": "server.js",
  "scripts": {
    "start": "node db/migrate.js && node server.js",
    "migrate": "node db/migrate.js",
    "db:backup": "pg_dump \"$DATABASE_URL\" --no-owner --no-acl --format=custom --file=backup-$(date +%Y%m%d-%H%M%S).dump"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "bcrypt": "^5.1.1",
    "connect-pg-simple": "^9.0.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.18.0",
    "multer": "^2.1.1",
    "nodemailer": "^6.9.15",
    "pdfkit": "^0.15.0",
    "pg": "^8.12.0"
  }
}
