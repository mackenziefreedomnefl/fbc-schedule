# Postgres connection (Railway provides DATABASE_URL automatically)
DATABASE_URL=postgres://user:password@localhost:5432/schedule_dashboard

# Session secret — generate a long random string for production
SESSION_SECRET=change-me-to-a-long-random-string

# First-run admin bootstrap (only used if no admin exists yet)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-on-first-login

# Optional: port (Railway sets this automatically)
PORT=3000

# Optional: set to "true" if connecting to Postgres over SSL (Railway managed PG requires this)
PGSSL=true
